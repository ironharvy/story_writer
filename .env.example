# Model configuration
MODEL=openai/gpt-4o-mini
LLM_URL=
API_KEY=

# DSPy cache
DSPY_CACHE_DIR=

# Replicate (image generation)
REPLICATE_API_TOKEN=

# Logging
# LOG_LEVEL=INFO        # Override log level (DEBUG, INFO, WARNING, ERROR)
# LOG_FORMAT=text       # "text" for human-readable, "json" for structured
# LOG_FILE=             # Optional path to write logs to (always JSON)

# Langfuse (LLM observability — https://langfuse.com)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
